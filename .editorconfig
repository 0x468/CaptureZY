root = true

[*.{cpp,h,hpp,ixx,cxx,cc}]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cmake,txt,md,yml,yaml,json}]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[CMakeLists.txt]
indent_size = 2
