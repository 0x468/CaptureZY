CompileFlags:
  CompilationDatabase: out/build/windows-msvc
  Add: ['-std:c++latest']

---
If:
  PathMatch: .*\\.(h|hpp)$
CompileFlags:
  Add:
    -xc++
    -std:c++latest

Diagnostics:
  UnusedIncludes: Strict

Index:
  Background: Build

InlayHints:
  Enabled: true
  ParameterNames: true
  DeducedTypes: true

Hover:
  ShowAKA: true
